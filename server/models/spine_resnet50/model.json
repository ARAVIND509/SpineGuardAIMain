import * as tf from "@tensorflow/tfjs";
import sharp from "sharp";
import path from "path";

type SeverityLevel = "normal" | "mild" | "moderate" | "severe";

interface PredictionResult {
  condition: string;
  confidence: number;
  severity: SeverityLevel;
  modelType: string;
}

interface MLModelPredictions {
  predictions: PredictionResult[];
  modelUsed: string;
  processingTime: number;
}

class MedicalImageModel {

  private model: tf.GraphModel | null = null;
  private isLoaded: boolean = false;

  async initialize(): Promise<void> {

    if (this.isLoaded) return;

    try {

      console.log("Loading Spine AI ResNet50 model...");

      const modelPath = `file://${path.join(
        process.cwd(),
        "server/models/spine_resnet50/model.json"
      )}`;

      this.model = await tf.loadGraphModel(modelPath);

      this.isLoaded = true;

      console.log("Spine AI model loaded successfully");

    } catch (error) {

      console.error("Model loading failed:", error);
      throw new Error("Failed to load pretrained model");

    }
  }

  async preprocessImage(imageBuffer: Buffer): Promise<tf.Tensor> {

    const { data, info } = await sharp(imageBuffer)
      .resize(224, 224)
      .removeAlpha()
      .raw()
      .toBuffer({ resolveWithObject: true });

    const tensor = tf.tensor3d(
      new Uint8Array(data),
      [info.height, info.width, info.channels]
    );

    const normalized = tensor.div(255);

    const batched = normalized.expandDims(0);

    tensor.dispose();
    normalized.dispose();

    return batched;

  }

  async predict(imageBuffer: Buffer): Promise<MLModelPredictions> {

    const startTime = Date.now();

    await this.initialize();

    if (!this.model) {
      throw new Error("Model not initialized");
    }

    try {

      const inputTensor = await this.preprocessImage(imageBuffer);

      const outputTensor = this.model.predict(inputTensor) as tf.Tensor;

      const probabilities = Array.from(await outputTensor.data());

      inputTensor.dispose();
      outputTensor.dispose();

      const conditions = [
        "Disc Herniation",
        "Scoliosis",
        "Spinal Stenosis",
        "Degenerative Disc Disease",
        "Vertebral Fracture",
        "Spondylolisthesis",
        "Infection",
        "Tumor"
      ];

      const results: PredictionResult[] = conditions.map((condition, index) => {

        const confidence = Math.round((probabilities[index] ?? 0) * 100);

        let severity: SeverityLevel;

        if (confidence < 30) severity = "normal";
        else if (confidence >= 80) severity = "severe";
        else if (confidence >= 60) severity = "moderate";
        else severity = "mild";

        return {
          condition,
          confidence,
          severity,
          modelType: "ResNet50 Medical CNN"
        };

      });

      const processingTime = Date.now() - startTime;

      return {
        predictions: results,
        modelUsed: "ResNet50 Medical CNN",
        processingTime
      };

    } catch (error) {

      console.error("Prediction error:", error);
      throw new Error("AI prediction failed");

    }
  }

}

export const mlModel = new MedicalImageModel();

export async function analyzeMedicalImageWithML(
  imageBuffer: Buffer,




  
  modelType: "ResNet50" | "DenseNet121" | "MobileNet" = "ResNet50"
): Promise<MLModelPredictions> {




  return mlModel.predict(imageBuffer);

}

